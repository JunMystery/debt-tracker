<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Debttracker" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/dt_primary</item>
        <item name="colorOnPrimary">@color/dt_on_primary</item>
        <item name="colorPrimaryContainer">@color/dt_primary_container</item>
        <item name="colorSecondary">@color/dt_secondary</item>
        <item name="colorSurface">@color/dt_surface</item>
        <item name="colorOnSurface">@color/dt_on_surface</item>
        <item name="android:statusBarColor">@color/dt_primary</item>
        <item name="android:navigationBarColor">@color/dt_surface</item>
        <item name="android:windowBackground">@color/dt_background</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay_DebtTracker_MaterialAlertDialog</item>
    </style>

    <style name="Widget.DebtTracker.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/dt_surface</item>
        <item name="titleTextColor">@color/dt_on_surface</item>
        <item name="subtitleTextColor">@color/dt_secondary</item>
    </style>

    <style name="ThemeOverlay_DebtTracker_MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/dt_surface</item>
        <item name="colorOnSurface">@color/dt_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/dt_secondary</item>
        <item name="android:textColorPrimary">@color/dt_on_surface</item>
        <item name="android:textColorSecondary">@color/dt_secondary</item>
        <item name="android:background">@color/dt_surface</item>
        <item name="colorPrimary">@color/dt_primary</item>
        <item name="alertDialogStyle">@style/Widget_DebtTracker_MaterialAlertDialog</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget_DebtTracker_DialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget_DebtTracker_DialogButton</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget_DebtTracker_DialogButton</item>
    </style>

    <style name="Widget_DebtTracker_DialogButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/dt_primary</item>
        <item name="rippleColor">@color/dt_primary_container</item>
    </style>
</resources>
