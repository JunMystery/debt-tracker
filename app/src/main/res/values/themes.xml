<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Debttracker" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/dt_primary</item>
        <item name="colorOnPrimary">@color/dt_on_primary</item>
        <item name="colorPrimaryContainer">@color/dt_primary_container</item>
        <item name="colorSecondary">@color/dt_secondary</item>
        <item name="colorSurface">@color/dt_surface</item>
        <item name="colorOnSurface">@color/dt_on_surface</item>
        <item name="android:statusBarColor">@color/dt_primary</item>
        <item name="android:navigationBarColor">@color/dt_surface</item>
        <item name="android:windowBackground">@color/dt_background</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay_DebtTracker_MaterialAlertDialog</item>
    </style>

    <style name="Widget.DebtTracker.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/dt_surface</item>
        <item name="titleTextColor">@color/dt_on_surface</item>
        <item name="subtitleTextColor">@color/dt_secondary</item>
    </style>

    <style name="Widget.DebtTracker.IconButton" parent="Widget.AppCompat.ImageButton">
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:padding">6dp</item>
        <item name="android:tint">@color/dt_primary</item>
    </style>

    <style name="Widget_DebtTracker_NumberPicker">
        <item name="android:textColor">@color/dt_on_surface</item>
        <item name="android:textSize">26sp</item>
    </style>

    <style name="ThemeOverlay_DebtTracker_NumberPicker" parent="">
        <item name="colorControlNormal">@color/dt_primary</item>
        <item name="android:colorControlNormal">@color/dt_primary</item>
        <item name="android:textColorPrimary">@color/dt_on_surface</item>
        <item name="android:textColorSecondary">@color/dt_secondary</item>
        <item name="android:textSize">26sp</item>
    </style>

    <style name="ThemeOverlay_DebtTracker_MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/dt_surface</item>
        <item name="colorOnSurface">@color/dt_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/dt_secondary</item>
        <item name="android:textColorPrimary">@color/dt_on_surface</item>
        <item name="android:textColorSecondary">@color/dt_secondary</item>
        <item name="colorPrimary">@color/dt_primary</item>
    </style>

    <!-- Global, reusable TextInputLayout styles with premium white backgrounds and rounded corners -->
    <style name="Widget.DebtTracker.TextInputLayout.OutlinedBox" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/white</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="Widget.DebtTracker.TextInputLayout.OutlinedBox.ExposedDropdownMenu" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/white</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>
</resources>
