<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dt_background"
    android:fitsSystemWindows="true">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/dt_background"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/create_debt"
        app:titleTextColor="@color/dt_on_surface" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Creditor Name -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.DebtTracker.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/creditor_name">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editCreditor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Contract Number -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.DebtTracker.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/contract_number">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editContract"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapCharacters" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Due Day picker card -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/due_day_of_month"
                android:textColor="@color/dt_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDueDay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dt_outline"
                app:cardBackgroundColor="@color/dt_surface">

                <TextView
                    android:id="@+id/textDueDay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:textColor="@color/dt_on_surface"
                    android:textSize="14sp"
                    tools:text="Chọn ngày..." />
            </com.google.android.material.card.MaterialCardView>

            <!-- Monthly Amount -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.DebtTracker.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/monthly_amount">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editAmount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Start Date picker card -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/start_month_year"
                android:textColor="@color/dt_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStartDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dt_outline"
                app:cardBackgroundColor="@color/dt_surface">

                <TextView
                    android:id="@+id/textStartDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:textColor="@color/dt_on_surface"
                    android:textSize="14sp"
                    tools:text="Chọn tháng bắt đầu..." />
            </com.google.android.material.card.MaterialCardView>

            <!-- End Date picker card -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/end_month_year"
                android:textColor="@color/dt_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEndDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dt_outline"
                app:cardBackgroundColor="@color/dt_surface">

                <TextView
                    android:id="@+id/textEndDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:textColor="@color/dt_on_surface"
                    android:textSize="14sp"
                    tools:text="Chọn tháng kết thúc..." />
            </com.google.android.material.card.MaterialCardView>

            <!-- Interest Type Dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.DebtTracker.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/interest_type">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/interestTypeDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="@color/dt_on_surface"
                    android:saveEnabled="false"
                    android:popupBackground="@color/dt_surface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Payment Type Dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.DebtTracker.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/payment_type">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/paymentTypeDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="@color/dt_on_surface"
                    android:saveEnabled="false"
                    android:popupBackground="@color/dt_surface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Interest/Profit Rate -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/interestRateLayout"
                style="@style/Widget.DebtTracker.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/interest_rate">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editInterestRate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Credit Limit (visible only for REDUCING balance) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/creditLimitLayout"
                style="@style/Widget.DebtTracker.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                android:hint="@string/credit_limit">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editCreditLimit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Minimum Payment Percent (visible only for REDUCING balance) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/minPaymentPercentLayout"
                style="@style/Widget.DebtTracker.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                android:hint="@string/min_payment_percent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editMinPaymentPercent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Principal (Optional) -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.DebtTracker.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:hint="@string/principal_amount">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editPrincipal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:focusable="false"
                    android:cursorVisible="false"
                    android:clickable="false" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/dt_surface"
        android:padding="16dp"
        android:elevation="4dp"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/cancel"
            android:textColor="@color/dt_secondary"
            app:strokeColor="@color/dt_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:layout_marginStart="12dp"
            android:text="@string/save"
            app:backgroundTint="@color/dt_primary" />
    </LinearLayout>

</LinearLayout>
