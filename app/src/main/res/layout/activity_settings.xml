<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dt_background"
    android:fitsSystemWindows="true">

    <!-- Custom Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/dt_background"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/settings_title"
        app:titleTextColor="@color/dt_on_surface" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- General settings header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_general"
                android:textColor="@color/dt_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Language preference card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dt_outline"
                app:cardBackgroundColor="@color/dt_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_language"
                        android:textColor="@color/dt_on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <AutoCompleteTextView
                            android:id="@+id/autoCompleteLanguage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@color/dt_on_surface"
                            android:textSize="14sp"
                            android:saveEnabled="false"
                            android:popupBackground="@color/dt_surface"
                            tools:ignore="LabelFor" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Notifications settings header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_notifications"
                android:textColor="@color/dt_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Notifications card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dt_outline"
                app:cardBackgroundColor="@color/dt_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Global toggle -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:text="@string/enable_reminders"
                            android:textColor="@color/dt_on_surface"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchNotifications"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:useMaterialThemeColors="true" />

                    </RelativeLayout>

                    <!-- Settings parameters layout -->
                    <LinearLayout
                        android:id="@+id/layoutNotificationParams"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Remind offset (days) -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layoutRemindDays"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/remind_days_before"
                            android:layout_marginBottom="16dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editRemindDays"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textColor="@color/dt_on_surface"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Frequency dropdown -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/remind_frequency"
                            android:layout_marginBottom="16dp"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">

                            <AutoCompleteTextView
                                android:id="@+id/autoCompleteFrequency"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:textColor="@color/dt_on_surface"
                                android:textSize="14sp"
                                android:saveEnabled="false"
                                android:popupBackground="@color/dt_surface"
                                tools:ignore="LabelFor" />

                        </com.google.android.material.textfield.TextInputLayout>



                        <!-- Start Hour Selector -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/remind_start_hour"
                            android:textColor="@color/dt_secondary"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardStartHour"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:layout_marginBottom="16dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/dt_outline"
                            app:cardBackgroundColor="@color/dt_background">

                            <TextView
                                android:id="@+id/textStartHour"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="14dp"
                                android:textColor="@color/dt_on_surface"
                                android:textSize="14sp"
                                tools:text="09:00" />
                        </com.google.android.material.card.MaterialCardView>

                        <!-- End Hour Selector -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/remind_end_hour"
                            android:textColor="@color/dt_secondary"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardEndHour"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:layout_marginBottom="16dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="@color/dt_outline"
                            app:cardBackgroundColor="@color/dt_background">

                            <TextView
                                android:id="@+id/textEndHour"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="14dp"
                                android:textColor="@color/dt_on_surface"
                                android:textSize="14sp"
                                tools:text="21:00" />
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Preview layout -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="8dp">

                            <TextView
                                android:id="@+id/textPreviewHours"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:textColor="@color/dt_secondary"
                                android:textSize="13sp"
                                tools:text="Reminder hours: 09:00, 13:00, 17:00" />

                            <ImageButton
                                android:id="@+id/ibPreviewInfo"
                                style="@style/Widget.DebtTracker.IconButton"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_info"
                                android:contentDescription="@string/notification_preview_dialog_title" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Backup / Auto save header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_backup"
                android:textColor="@color/dt_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Backup card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dt_outline"
                app:cardBackgroundColor="@color/dt_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentStart="true"
                            android:layout_toStartOf="@id/switchAutoBackup"
                            android:layout_marginEnd="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/backup_auto_save"
                                android:textColor="@color/dt_on_surface"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/backup_auto_save_desc"
                                android:textColor="@color/dt_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchAutoBackup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:useMaterialThemeColors="true" />

                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Import / Restore header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_import"
                android:textColor="@color/dt_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Import card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dt_outline"
                app:cardBackgroundColor="@color/dt_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/import_title"
                        android:textColor="@color/dt_on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/import_desc"
                        android:textColor="@color/dt_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnImportCsv"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/import_button"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/dt_primary"
                        app:cornerRadius="8dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
